{
  "name": "backend",
  "version": "0.0.2",
  "description": "A Prebaked Medusa 2.0 backend",
  "author": "Rasmus Puls",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build && node src/scripts/postBuild.js",
    "seed": "node ./scripts/run-medusa.js ./src/scripts/seed.ts",
    "ib": "cd .medusa/server && node ./scripts/init-backend.js",
    "start": "cd .medusa/server && node ./scripts/init-backend.js && node ./node_modules/@medusajs/cli/cli.js start --verbose",
    "dev": "medusa develop",
    "email:dev": "pnpm dlx react-email@6.6.5 dev --dir=./src/modules/email-notifications/templates --port=3002",
    "search:rebuild": "node ./scripts/run-medusa.js ./src/scripts/reindex-meilisearch.ts",
    "search:check": "node ./scripts/run-medusa.js ./src/scripts/check-meilisearch-sync.ts",
    "search:sync-settings": "node ./scripts/run-medusa.js ./src/scripts/sync-meilisearch-settings.ts",
    "search:sync": "pnpm run search:sync-settings && pnpm run search:rebuild",
    "search:prepare": "pnpm run search:sync && pnpm run search:check",
    "discography:build": "node ./scripts/run-medusa.js ./src/scripts/build-discography-from-products.ts",
    "discography:normalize-formats": "node ./scripts/run-medusa.js ./src/scripts/normalize-discography-formats.ts",
    "news:seed": "node ./scripts/run-medusa.js ./src/scripts/seed-news.ts",
    "catalog:shelves:seed": "node ./scripts/run-medusa.js ./src/scripts/seed-catalog-shelves.ts",
    "shipping:update": "node ./scripts/run-medusa.js ./src/scripts/update-shipping-options.ts",
    "region:us-only": "node ./scripts/run-medusa.js ./src/scripts/enforce-us-region.ts",
    "test": "jest --runInBand --passWithNoTests",
    "lint": "eslint --ext .ts,.tsx --max-warnings=0 src"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@medusajs/admin-sdk": "^2.17.1",
    "@medusajs/admin-shared": "^2.17.1",
    "@medusajs/cli": "^2.17.1",
    "@medusajs/core-flows": "^2.17.1",
    "@medusajs/dashboard": "^2.17.1",
    "@medusajs/draft-order": "^2.17.1",
    "@medusajs/event-bus-redis": "^2.17.1",
    "@medusajs/file": "^2.17.1",
    "@medusajs/framework": "^2.17.1",
    "@medusajs/fulfillment": "^2.17.1",
    "@medusajs/fulfillment-manual": "^2.17.1",
    "@medusajs/icons": "^2.17.1",
    "@medusajs/medusa": "^2.17.1",
    "@medusajs/notification": "^2.17.1",
    "@medusajs/notification-sendgrid": "^2.17.1",
    "@medusajs/payment": "^2.17.1",
    "@medusajs/payment-stripe": "^2.17.1",
    "@medusajs/tax": "^2.17.1",
    "@medusajs/ui": "^4.1.18",
    "@medusajs/utils": "^2.17.1",
    "@medusajs/workflow-engine-redis": "^2.17.1",
    "@mikro-orm/core": "6.6.14",
    "@mikro-orm/knex": "6.6.14",
    "@mikro-orm/migrations": "6.6.14",
    "@mikro-orm/postgresql": "6.6.14",
    "@react-email/render": "2.0.9",
    "@rokmohar/medusa-plugin-meilisearch": "^1.4.3",
    "awilix": "^8.0.1",
    "csv-parse": "^5.6.0",
    "medusajs-launch-utils": "^0.0.18",
    "minio": "^8.0.3",
    "pg": "^8.13.1",
    "posthog-node": "^5.38.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "redis": "^4.7.1",
    "resend": "6.16.0",
    "stripe": "^22.3.0",
    "ts-node": "^10.9.2",
    "ulid": "^2.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@medusajs/test-utils": "^2.17.1",
    "@mikro-orm/cli": "6.6.14",
    "@swc/core": "1.15.43",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.38.0",
    "jest": "^30.4.2",
    "prop-types": "^15.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.2"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11.0.0 <12"
  }
}
